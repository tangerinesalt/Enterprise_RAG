# ====================================
# RAG V — 环境变量配置示例
# ====================================
# 复制此文件为 .env 后按需修改

# --- LLM ---
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Embedding ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Vector Database ---
VECTOR_DB_TYPE=chroma
VECTOR_DB_PATH=./storage/vector_db

# --- 文档存储 ---
DOC_STORAGE_PATH=./storage/documents

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# --- Logging ---
LOG_LEVEL=INFO
